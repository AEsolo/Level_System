{ label: “E”, color: “#9ca3af”, xp: 30,  desc: “Trivial”    },
{ label: “D”, color: “#22c55e”, xp: 75,  desc: “Leicht”     },
{ label: “C”, color: “#3b82f6”, xp: 150, desc: “Normal”     },
{ label: “B”, color: “#a855f7”, xp: 300, desc: “Schwer”     },
{ label: “A”, color: “#f59e0b”, xp: 500, desc: “Episch”     },
{ label: “S”, color: “#ef4444”, xp: 800, desc: “Legendär”   },
];

const STATS = [
{ id: “strength”,  label: “Stärke”,    icon: “⚔️”,  color: “#ef4444” },
{ id: “agility”,   label: “Agilität”,  icon: “💨”,  color: “#22c55e” },
{ id: “mind”,      label: “Geist”,     icon: “🧠”,  color: “#a855f7” },
{ id: “presence”,  label: “Präsenz”,   icon: “👁️”,  color: “#f59e0b” },
{ id: “health”,    label: “Gesundheit”,icon: “💚”,  color: “#06b6d4” },
];

const XP_PER_LEVEL = (lvl) => Math.floor(100 * Math.pow(1.25, lvl - 1));

const calcLevel = (totalXp) => {
let lvl = 1, xp = totalXp;
while (xp >= XP_PER_LEVEL(lvl)) { xp -= XP_PER_LEVEL(lvl); lvl++; }
return { level: lvl, current: xp, needed: XP_PER_LEVEL(lvl) };
};

const OVERALL_LEVEL = (stats) => {
const avg = Object.values(stats).reduce((s, v) => s + calcLevel(v).level, 0) / STATS.length;
return Math.floor(avg);
};

