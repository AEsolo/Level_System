// ─── MAIN APP ─────────────────────────────────────────────────────────────────
export default function App() {
const [state, setState] = useState(DEFAULT_STATE);
const [view, setView] = useState(“home”);
const [notif, setNotif] = useState(null);
const [loaded, setLoaded] = useState(false);

// Load from storage
useEffect(() => {
(async () => {
try {
const res = await window.storage.get(“sl-state”);
if (res?.value) setState(JSON.parse(res.value));
} catch {}
setLoaded(true);
})();
}, []);

// Save to storage
const save = useCallback(async (s) => {
try { await window.storage.set(“sl-state”, JSON.stringify(s)); } catch {}
}, []);

const update = useCallback((patch) => {
setState(prev => { const next = {…prev, …patch}; save(next); return next; });
}, [save]);

const showNotif = (msg) => setNotif(msg);

const handleComplete = (id) => {
setState(prev => {
const quest = prev.quests.find(q => q.id === id);
if (!quest || quest.done) return prev;
const next = {
…prev,
quests: prev.quests.map(q => q.id === id ? {…q, done: true, doneAt: Date.now()} : q),
statXp: {…prev.statXp, [quest.stat]: prev.statXp[quest.stat] + quest.xp},
};
save(next);
const stat = STATS.find(s => s.id === quest.stat);
showNotif(`+${quest.xp} ${stat.label}-XP erhalten!`);
return next;
});
};

const handleAdd = (quest) => {
setState(prev => { const next = {…prev, quests: […prev.quests, quest]}; save(next); return next; });
};

const handleDelete = (id) => {
setState(prev => { const next = {…prev, quests: prev.quests.filter(q => q.id !== id)}; save(next); return next; });
};

const handleReset = () => {
if (!window.confirm(“System wirklich zurücksetzen?”)) return;
const fresh = {…DEFAULT_STATE, playerName: state.playerName};
setState(fresh);
save(fresh);
};

if (!loaded) return (
<div style={{ minHeight: “100vh”, background: GS.bg, display: “flex”, alignItems: “center”, justifyContent: “center” }}>
<div style={{ fontFamily: “Cinzel”, color: GS.glow, fontSize: 16, letterSpacing: 4 }} className=“pulse”>
SYSTEM LÄDT…
</div>
</div>
);

return (
<>
<style>{css}</style>
<div className="app hex-bg">
{notif && <Notif msg={notif} onDone={() => setNotif(null)} />}

```
    {view === "home"     && <HomeView state={state} />}
    {view === "quests"   && <QuestsView state={state} onComplete={handleComplete} onAdd={handleAdd} onDelete={handleDelete} />}
    {view === "stats"    && <StatsView state={state} />}
    {view === "settings" && <SettingsView state={state} onUpdate={update} onReset={handleReset} />}

    <nav className="nav">
      {[
        { id: "home",     icon: "⬡",  label: "Home"    },
        { id: "quests",   icon: "📋", label: "Quests"  },
        { id: "stats",    icon: "📊", label: "Stats"   },
        { id: "settings", icon: "⚙️", label: "System"  },
      ].map(b => (
        <button key={b.id} className={`nav-btn ${view === b.id ? "active" : ""}`} onClick={() => setView(b.id)}>
          <span className="nav-icon">{b.icon}</span>
          {b.label}
        </button>
      ))}
    </nav>
  </div>
</>
