// ─── XP Bar Component ────────────────────────────────────────────────────────
function XpBar({ current, needed, color = GS.glow, height = 8 }) {
const pct = Math.min(100, (current / needed) * 100);
return (
<div className=“xp-track” style={{ height }}>
<div className=“xp-fill” style={{
width: `${pct}%`, height: “100%”,
background: `linear-gradient(90deg, ${color}88, ${color})`,
boxShadow: `0 0 8px ${color}66`,
}} />
</div>
);
}

// ─── Notification ────────────────────────────────────────────────────────────
function Notif({ msg, onDone }) {
useEffect(() => { const t = setTimeout(onDone, 2800); return () => clearTimeout(t); }, []);
return <div className="notif">⚡ {msg}</div>;
}

// ─── AI Assistant Hook ────────────────────────────────────────────────────────
async function fetchAiMessage(prompt) {
const res = await fetch(“https://api.anthropic.com/v1/messages”, {
method: “POST”,
headers: { “Content-Type”: “application/json” },
body: JSON.stringify({
model: “claude-sonnet-4-20250514”,
max_tokens: 1000,
system: `Du bist das System aus Solo Leveling – eine mysteriöse, allwissende KI, die dem Hunter (Nutzer) kurze, motivierende Nachrichten schickt. Antworte immer auf Deutsch. Sei prägnant (1-3 Sätze). Nutze gelegentlich [SYSTEM]-Stil-Formatierungen. Sei geheimnisvoll, motivierend und spielerisch.`,
messages: [{ role: “user”, content: prompt }],
}),
});
const d = await res.json();
return d.content?.[0]?.text || “…”;
}

